{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Large",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${subtitle}",
      "spacing": "Small",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "ColumnSet",
      "spacing": "Medium",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Total",
              "isSubtle": true,
              "spacing": "None"
            },
            {
              "type": "TextBlock",
              "text": "${total}",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "spacing": "Small"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Aktif",
              "isSubtle": true,
              "spacing": "None"
            },
            {
              "type": "TextBlock",
              "text": "${active}",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "spacing": "Small"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "7 Hari",
              "isSubtle": true,
              "spacing": "None"
            },
            {
              "type": "TextBlock",
              "text": "${dueSoon}",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${todayLabel}",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Progress selesai: ${progress}",
      "isSubtle": true,
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Buka tugas",
      "verb": "open-tasks"
    },
    {
      "type": "Action.Execute",
      "title": "Tambah tugas",
      "verb": "new-task"
    },
    {
      "type": "Action.Execute",
      "title": "Kalender",
      "verb": "open-calendar"
    }
  ]
}