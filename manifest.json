{
  "id": "./",
  "name": "TugasKu - Tugas Aman, Masa Depan Nyaman",
  "short_name": "TugasKu",
  "description": "Aplikasi PWA manajemen tugas mahasiswa dengan halaman terpisah, responsif, dan nyaman dipakai di perangkat mobile.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#FBFDFF",
  "theme_color": "#2563EB",
  "orientation": "portrait",
  "lang": "id",
  "icons": [
    {
      "src": "icons/icon-192x192-A.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512x512-B.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tampilan onboarding atau contoh layar aplikasi mobile."
    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tampilan kedua aplikasi pada mode portrait."
    }
  ],
  "shortcuts": [
    {
      "name": "Tambah Tugas",
      "short_name": "Tambah",
      "url": "./tambah.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Kalender Deadline",
      "short_name": "Kalender",
      "url": "./kalender.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "categories": [
    "productivity",
    "education",
    "utilities"
  ],
  "dir": "ltr",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "browser"
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "prefer_related_applications": false,
  "note_taking": {
    "new_note_url": "./tambah.html"
  },
  "share_target": {
    "action": "./tambah.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+tugasku",
      "url": "./tambah.html?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "./tambah.html",
      "accept": {
        "application/json": [
          ".json"
        ],
        "text/plain": [
          ".txt"
        ]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 420
  }
}
