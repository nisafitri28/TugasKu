{
  "id": "./",
  "name": "TugasKu - Tugas Aman, Masa Depan Nyaman",
  "short_name": "TugasKu",
  "description": "Aplikasi PWA manajemen tugas mahasiswa untuk mencatat deadline, membuka file tugas, menerima share, dan tetap produktif secara offline.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#F0F6FB",
  "theme_color": "#2563EB",
  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",
  "categories": [
    "productivity",
    "education",
    "utilities"
  ],
  "icons": [
    {
      "src": "icons/icon-192x192-A.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512x512-B.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Beranda TugasKu pada tampilan mobile"
    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Form tambah tugas pada tampilan mobile"
    },
    {
      "src": "icons/screenshot3.png",
      "sizes": "2860x1537",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard TugasKu pada desktop"
    },
    {
      "src": "icons/screenshot4.png",
      "sizes": "2864x1530",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Daftar tugas dan filter prioritas pada desktop"
    },
    {
      "src": "icons/screenshot5.png",
      "sizes": "2871x1536",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Kalender deadline kuliah pada desktop"
    },
    {
      "src": "icons/screenshot6.png",
      "sizes": "2870x1528",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Statistik progres tugas pada desktop"
    },
    {
      "src": "icons/screenshot7.png",
      "sizes": "2866x1528",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Halaman mata kuliah aktif pada desktop"
    },
    {
      "src": "icons/screenshot8.png",
      "sizes": "2877x1529",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Pengaturan tema dan reminder pada desktop"
    }
  ],
  "shortcuts": [
    {
      "name": "Tambah Tugas",
      "short_name": "Tambah",
      "description": "Buat tugas baru dengan deadline dan prioritas.",
      "url": "./tambah.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Kalender Deadline",
      "short_name": "Kalender",
      "description": "Lihat deadline kuliah paling dekat.",
      "url": "./kalender.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Daftar Tugas",
      "short_name": "Tugas",
      "description": "Kelola, cari, dan arsipkan semua tugas.",
      "url": "./tugas.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Catatan Cepat",
      "short_name": "Catat",
      "description": "Buka form catatan atau tugas baru dengan cepat.",
      "url": "./tambah.html?source=note",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "share_target": {
    "action": "./tambah.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+tugasku",
      "url": "./tambah.html?protocol=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "./tambah.html",
      "accept": {
        "application/json": [
          ".json",
          ".tugasku"
        ],
        "text/plain": [
          ".txt",
          ".md"
        ]
      }
    }
  ],
  "widgets": [
    {
      "name": "Ringkasan TugasKu",
      "short_name": "Ringkasan",
      "description": "Widget ringkasan tugas aktif, deadline terdekat, dan aksi cepat untuk Windows.",
      "tag": "tugasku-summary",
      "template": "tugasku-summary-template",
      "ms_ac_template": "widgets/tugasku-widget-template.json",
      "data": "widgets/tugasku-widget-data.json",
      "type": "application/json",
      "auth": false,
      "update": 86400,
      "multiple": false,
      "screenshots": [
        {
          "src": "widgets/widget-screenshot.png",
          "sizes": "600x400",
          "type": "image/png",
          "platform": "windows",
          "label": "Widget ringkasan TugasKu di Windows Widgets Board"
        }
      ],
      "icons": [
        {
          "src": "widgets/widget-icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        },
        {
          "src": "widgets/widget-icon-128.png",
          "sizes": "128x128",
          "type": "image/png"
        },
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png"
        },
        {
          "src": "widgets/widget-icon-256.png",
          "sizes": "256x256",
          "type": "image/png"
        },
        {
          "src": "icons/icon-512x512-B.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "tab_strip": {
    "new_tab_button": {
      "url": "./tambah.html"
    }
  },
  "note_taking": {
    "new_note_url": "./tambah.html?source=note"
  },
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "./manifest.json",
      "id": "./"
    }
  ],
  "iarc_rating_id": "REQUIRES_REAL_IARC_CERTIFICATE_ID",
  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://example.com"
    }
  ]
}
